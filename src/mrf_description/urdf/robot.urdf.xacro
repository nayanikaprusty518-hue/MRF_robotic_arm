<?xml version="1.0"?>
<!-- Single MRF sorting arm + ros2_control. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="kr_arm">

  <xacro:include filename="$(find mrf_description)/urdf/kr_arm.xacro"/>

  <!-- shared world frame -->
  <link name="world"/>

  <!-- single arm, mounted at origin, reaching the belt from +Y -->
  <xacro:kr_arm prefix="a1_" mount_x="0"  mount_y="0"     mount_z="0.80"
                mount_yaw="0"       color="1.0 0.45 0.0 1.0"/>

  <!-- ros2_control: one GazeboSystem driving the arm joints -->
  <xacro:macro name="arm_jc" params="name">
    <joint name="${name}">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <ros2_control name="GazeboSystem" type="system">
    <hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>
    <xacro:arm_jc name="a1_joint1"/><xacro:arm_jc name="a1_joint2"/><xacro:arm_jc name="a1_joint3"/>
    <xacro:arm_jc name="a1_joint4"/><xacro:arm_jc name="a1_joint5"/><xacro:arm_jc name="a1_joint6"/>
    <xacro:arm_jc name="a1_finger1_joint"/><xacro:arm_jc name="a1_finger2_joint"/><xacro:arm_jc name="a1_finger3_joint"/>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find mrf_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
