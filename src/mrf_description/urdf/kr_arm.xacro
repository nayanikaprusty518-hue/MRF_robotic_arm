<?xml version="1.0"?>
<!--
  MRF sorting arm: a generic 6R industrial manipulator with a spherical wrist,
  packaged as a macro so it can be instantiated more than once (e.g. two arms
  facing each other across the conveyor).

  Geometry (must match the coordinator IK in ik.py):
    d1 = 0.40   base_link -> shoulder (joint2) along Z
    a2 = 0.45   upper arm (shoulder -> elbow)
    d4 = 0.42   forearm   (elbow -> wrist center)
    d6 = 0.15   wrist center -> tool tip (TCP)

  Links carry NO collision geometry (the arm is kinematically controlled and
  grasps kinematically; collisions would only cause physics instability). The
  base is anchored to a shared `world` link.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="kr_arm">

  <xacro:property name="d1" value="0.40"/>
  <xacro:property name="a2" value="0.45"/>
  <xacro:property name="d4" value="0.42"/>
  <xacro:property name="d6" value="0.15"/>

  <!-- top-level helper macros (defined once) -->
  <xacro:macro name="cyl_link" params="name length radius mat *origin">
    <link name="${name}">
      <visual>
        <xacro:insert_block name="origin"/>
        <geometry><cylinder length="${length}" radius="${radius}"/></geometry>
        <material name="${mat}"/>
      </visual>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- One finger of a claw gripper. The knuckle joint sits at radius R around
       the palm in direction `yaw`; the finger frame is rotated by `yaw` so the
       hooked geometry is defined once in local coords (local -X = inward).
       Positive joint angle (about local -Y) curls the finger inward to close. -->
  <xacro:macro name="claw_finger" params="fname parent mat px py yaw">
    <link name="${fname}">
      <!-- proximal segment, points along +Z (toward the workpiece) -->
      <visual>
        <origin xyz="0 0 0.05"/>
        <geometry><box size="0.022 0.03 0.10"/></geometry>
        <material name="${mat}"/>
      </visual>
      <!-- hooked tip, angled inward (toward local -X) for a claw look -->
      <visual>
        <origin xyz="-0.018 0 0.105" rpy="0 -0.6 0"/>
        <geometry><box size="0.02 0.028 0.055"/></geometry>
        <material name="${mat}"/>
      </visual>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${fname}_joint" type="revolute">
      <parent link="${parent}"/><child link="${fname}"/>
      <origin xyz="${px} ${py} 0.04" rpy="0 0 ${yaw}"/>
      <axis xyz="0 -1 0"/>
      <limit lower="-0.2" upper="1.2" effort="20" velocity="3.0"/>
    </joint>
  </xacro:macro>

  <!-- the arm itself -->
  <xacro:macro name="kr_arm" params="prefix mount_x mount_y mount_z mount_yaw color">

    <material name="${prefix}arm_color"><color rgba="${color}"/></material>
    <material name="${prefix}dark"><color rgba="0.15 0.15 0.15 1.0"/></material>

    <joint name="${prefix}world_joint" type="fixed">
      <parent link="world"/><child link="${prefix}base_link"/>
      <origin xyz="${mount_x} ${mount_y} ${mount_z}" rpy="0 0 ${mount_yaw}"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0.05"/>
        <geometry><cylinder length="0.1" radius="0.16"/></geometry>
        <material name="${prefix}dark"/>
      </visual>
      <inertial>
        <mass value="10.0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
      </inertial>
    </link>

    <xacro:cyl_link name="${prefix}link1" length="${d1}" radius="0.13" mat="${prefix}arm_color">
      <origin xyz="0 0 ${d1/2}"/>
    </xacro:cyl_link>
    <joint name="${prefix}joint1" type="revolute">
      <parent link="${prefix}base_link"/><child link="${prefix}link1"/>
      <origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
      <limit lower="-3.5" upper="3.5" effort="200" velocity="2.5"/>
    </joint>

    <xacro:cyl_link name="${prefix}link2" length="${a2}" radius="0.10" mat="${prefix}arm_color">
      <origin xyz="0 0 ${a2/2}"/>
    </xacro:cyl_link>
    <joint name="${prefix}joint2" type="revolute">
      <parent link="${prefix}link1"/><child link="${prefix}link2"/>
      <origin xyz="0 0 ${d1}"/><axis xyz="0 1 0"/>
      <limit lower="-2.5" upper="2.5" effort="200" velocity="2.0"/>
    </joint>

    <xacro:cyl_link name="${prefix}link3" length="${d4}" radius="0.085" mat="${prefix}arm_color">
      <origin xyz="0 0 ${d4/2}"/>
    </xacro:cyl_link>
    <joint name="${prefix}joint3" type="revolute">
      <parent link="${prefix}link2"/><child link="${prefix}link3"/>
      <origin xyz="0 0 ${a2}"/><axis xyz="0 1 0"/>
      <limit lower="-2.8" upper="2.8" effort="200" velocity="2.0"/>
    </joint>

    <xacro:cyl_link name="${prefix}link4" length="0.10" radius="0.07" mat="${prefix}dark">
      <origin xyz="0 0 0.05"/>
    </xacro:cyl_link>
    <joint name="${prefix}joint4" type="revolute">
      <parent link="${prefix}link3"/><child link="${prefix}link4"/>
      <origin xyz="0 0 ${d4}"/><axis xyz="0 0 1"/>
      <limit lower="-3.14" upper="3.14" effort="50" velocity="3.0"/>
    </joint>

    <xacro:cyl_link name="${prefix}link5" length="0.08" radius="0.06" mat="${prefix}arm_color">
      <origin xyz="0 0 0.0"/>
    </xacro:cyl_link>
    <joint name="${prefix}joint5" type="revolute">
      <parent link="${prefix}link4"/><child link="${prefix}link5"/>
      <origin xyz="0 0 0.0"/><axis xyz="0 1 0"/>
      <limit lower="-2.8" upper="2.8" effort="50" velocity="3.0"/>
    </joint>

    <link name="${prefix}link6">
      <visual>
        <origin xyz="0 0 0.025"/>
        <geometry><cylinder length="0.05" radius="0.05"/></geometry>
        <material name="${prefix}dark"/>
      </visual>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${prefix}joint6" type="revolute">
      <parent link="${prefix}link5"/><child link="${prefix}link6"/>
      <origin xyz="0 0 0.0"/><axis xyz="0 0 1"/>
      <limit lower="-3.14" upper="3.14" effort="50" velocity="3.0"/>
    </joint>

    <!-- round palm of the claw -->
    <link name="${prefix}gripper_base">
      <visual>
        <origin xyz="0 0 0.025"/>
        <geometry><cylinder length="0.05" radius="0.055"/></geometry>
        <material name="${prefix}dark"/>
      </visual>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
    </link>
    <joint name="${prefix}gripper_mount" type="fixed">
      <parent link="${prefix}link6"/><child link="${prefix}gripper_base"/>
      <origin xyz="0 0 0.05"/>
    </joint>

    <!-- three claw fingers spaced 120 deg around the palm -->
    <xacro:claw_finger fname="${prefix}finger1" parent="${prefix}gripper_base" mat="${prefix}dark"
                       px="0.042"  py="0.0"    yaw="0"/>
    <xacro:claw_finger fname="${prefix}finger2" parent="${prefix}gripper_base" mat="${prefix}dark"
                       px="-0.021" py="0.036"  yaw="2.0944"/>
    <xacro:claw_finger fname="${prefix}finger3" parent="${prefix}gripper_base" mat="${prefix}dark"
                       px="-0.021" py="-0.036" yaw="-2.0944"/>

    <link name="${prefix}tcp"/>
    <joint name="${prefix}tcp_joint" type="fixed">
      <parent link="${prefix}link6"/><child link="${prefix}tcp"/>
      <origin xyz="0 0 ${d6}"/>
    </joint>

    <gazebo reference="${prefix}link1"><material>Gazebo/Orange</material></gazebo>
    <gazebo reference="${prefix}link2"><material>Gazebo/Orange</material></gazebo>
    <gazebo reference="${prefix}link3"><material>Gazebo/Orange</material></gazebo>
    <gazebo reference="${prefix}link5"><material>Gazebo/Orange</material></gazebo>
    <gazebo reference="${prefix}base_link"><material>Gazebo/FlatBlack</material></gazebo>
    <gazebo reference="${prefix}link4"><material>Gazebo/FlatBlack</material></gazebo>
    <gazebo reference="${prefix}link6"><material>Gazebo/FlatBlack</material></gazebo>
    <gazebo reference="${prefix}gripper_base"><material>Gazebo/FlatBlack</material></gazebo>
    <gazebo reference="${prefix}finger1"><material>Gazebo/FlatBlack</material></gazebo>
    <gazebo reference="${prefix}finger2"><material>Gazebo/FlatBlack</material></gazebo>
    <gazebo reference="${prefix}finger3"><material>Gazebo/FlatBlack</material></gazebo>

  </xacro:macro>
</robot>
